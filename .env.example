# Google Search Console API (scripts/gsc.mjs)
# Paste the full service account JSON key as a single line, or path to key file.
GSC_SERVICE_ACCOUNT_JSON=

# Optional: property URL (auto-detected if omitted)
# GSC_SITE_URL=sc-domain:pppoker.mn

# For GitHub Actions: add the same values as repository secrets
# (Settings → Secrets and variables → Actions):
#   GSC_SERVICE_ACCOUNT_JSON — required to enable the optional gsc CI job
#   GSC_SITE_URL             — optional
